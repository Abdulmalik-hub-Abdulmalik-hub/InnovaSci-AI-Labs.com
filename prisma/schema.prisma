generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  SYSTEM_ADMINISTRATOR
  CEO
  CTO
  CSO_RESEARCH_DIRECTOR
  CPO_HEAD_OF_EDTECH
  CFO
  VP_OF_ENGINEERING
  DIRECTOR_OF_CURRICULUM
  OPERATIONS_HR_MANAGER
  PRODUCT_MARKETING_MANAGER
  PRINCIPAL_AI_ML_RESEARCHER
  SENIOR_FULL_STACK_ENGINEER
  SENIOR_DATA_SCIENTIST
  SENIOR_UI_UX_DESIGNER
  MID_JUNIOR_SOFTWARE_ENGINEER
  DEVOPS_SYSADMIN
  INSTRUCTOR_SME
  SCIENTIFIC_RESEARCH_ASSOCIATE
  COMMUNITY_FORUM_MANAGER
  STUDENT_SUCCESS_PARTNER
  MARKETING_CONTENT_ASSOCIATE
  VISITOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         RoleType @default(VISITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile              UserProfile?
  assignedTasks        Task[]          @relation("AssignedTasks")
  createdTasks         Task[]          @relation("CreatedTasks")
  blogPosts            BlogPost[]
  forumThreads         ForumThread[]
  forumPosts           ForumPost[]
  auditLogs            AuditLog[]
  newsletterCampaigns   NewsletterCampaign[]

  @@map("users")
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl     String?
  bio           String   @db.Text
  qualification String?
  achievements  String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_profiles")
}

model SubBranch {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  tagline      String
  description  String   @db.Text
  thumbnailUrl String?
  branchUrl    String?
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sub_branches")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  status      String   @default("TODO")
  priority    String   @default("MEDIUM")
  creatorId   String
  creator     User     @relation("CreatedTasks", fields: [creatorId], references: [id])
  assigneeId  String?
  assignee    User?    @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  tagline      String?
  description  String   @db.Text
  thumbnailUrl String?
  productUrl   String?
  category     String?
  status       String   @default("DRAFT")
  metrics      String?
  docsLink     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  benchmarks ProductBenchmark[]

  @@map("products")
}

model ProductBenchmark {
  id              String  @id @default(cuid())
  productId       String
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  metricName      String
  ourScore        Float
  competitorName  String?
  competitorScore Float?

  @@map("product_benchmarks")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  tagline     String?
  description String   @db.Text
  category    String?
  status      String   @default("DRAFT")
  pricing     String?
  features    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  summary     String?
  featuredImg String?
  category    String?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  readTime    Int       @default(5)
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model NewsletterSubscriber {
  id               String    @id @default(cuid())
  email            String    @unique
  unsubscribeToken  String    @unique @default(cuid())
  isActive         Boolean   @default(true)
  subscribedAt      DateTime  @default(now())
  unsubscribedAt   DateTime?

  @@map("newsletter_subscribers")
}

model NewsletterCampaign {
  id        String    @id @default(cuid())
  subject   String
  content   String    @db.Text
  status    String    @default("DRAFT")
  sentById  String?
  sentBy    User?     @relation(fields: [sentById], references: [id])
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("newsletter_campaigns")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model ResearchPaper {
  id          String    @id @default(cuid())
  title       String
  abstract    String    @db.Text
  pdfUrl      String?
  publishDate DateTime?
  authors     String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("research_papers")
}

model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads ForumThread[]

  @@map("forum_categories")
}

model ForumThread {
  id         String   @id @default(cuid())
  title      String
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  isPinned   Boolean  @default(false)
  isLocked   Boolean  @default(false)
  isHidden   Boolean  @default(false)
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  posts ForumPost[]

  @@map("forum_threads")
}

model ForumPost {
  id        String   @id @default(cuid())
  content   String   @db.Text
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  parentId  String?
  parent    ForumPost? @relation("Replies", fields: [parentId], references: [id])
  replies   ForumPost[] @relation("Replies")
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("forum_posts")
}

model AISession {
  id        String   @id @default(cuid())
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AIMessage[]

  @@map("ai_sessions")
}

model AIMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@map("ai_messages")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
